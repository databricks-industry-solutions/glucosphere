# .env.bundle.example — template for per-target bundle deploy config.
#
# ░░ ONE FILE PER DEPLOY TARGET ░░
# Copy this template to `.env.bundle.<target-key>` for EACH target you deploy,
# where <target-key> exactly matches a key under `targets:` in `databricks.yml`
# (gsphere, gsphere_synth_e2e, gsphere_from_table_e2e, gsphere_from_source_e2e, …).
# Then deploy with name parity:
#
#     source .env.bundle.<target-key>
#     databricks bundle deploy -t <target-key>
#
# Each file carries that ONE target's complete coords. There is no shared mutable
# config and no HARNESS_TYPE conditional, so you can never "source the wrong one
# last" and silently deploy a target with another target's catalog/schema — the
# root cause of past wrong-schema / SQL-403 drift. All `.env.bundle.*` files are
# gitignored (workspace-specific); only this `.example` is committed.
#
# Full deploy sequence (per target):
#   1.  cp .env.bundle.example .env.bundle.<target-key>
#   2.  Fill in the required exports below for THAT target
#   3.  source .env.bundle.<target-key>
#   4.  databricks bundle deploy -t <target-key>          # pass 1 — creates the bundle-managed warehouse
#   5.  uv run python scripts/render_app_yaml.py --target <target-key>   # discovers warehouse → rewrites app.yaml
#   6.  databricks bundle deploy -t <target-key>          # pass 2 — picks up rendered app.yaml
#   7.  databricks bundle run glucosphere_full_setup -t <target-key>
#   8.  databricks bundle run glucosphere_app -t <target-key>   # deploys App source; without this the App stays UNAVAILABLE
#
# How values flow: `BUNDLE_VAR_<name>` env vars override the `variables:` defaults
# in `databricks.yml`; `DATABRICKS_CONFIG_PROFILE` selects the ~/.databrickscfg
# profile that supplies workspace host + auth (databricks.yml does NOT hardcode
# workspace.host, so any target can deploy to any workspace via this profile).
#
# NOTE: every variable line uses `export` — without it the value stays shell-local
# and the `databricks` CLI subprocess does not see it, silently falling back to the
# databricks.yml defaults.

# NOTE: Databricks CLI v1.x needs DATABRICKS_AUTH_STORAGE=plaintext in its env or it
# fails with "stored credentials from older CLI versions are no longer used". Harmless
# on older CLI versions. scripts/smoke_test.py injects this internally; shell deploys
# (databricks bundle deploy / run) should export it here once.
export DATABRICKS_AUTH_STORAGE=plaintext

# ─── REQUIRED — Unity Catalog catalog where the pipeline writes data ───
# Pre-create with `CREATE CATALOG IF NOT EXISTS <name>` if it doesn't exist yet.
export BUNDLE_VAR_catalog=your_workspace_catalog

# ─── REQUIRED — schema (database) inside the catalog above ───
# Set the FULL schema explicitly per target (no auto-suffixing). Use a distinct
# schema per harness/sandbox target for data isolation, e.g.:
#   gsphere                  → glucosphere
#   gsphere_synth_e2e        → glucosphere_synth_e2e
#   gsphere_from_source_e2e  → glucosphere_from_source_e2e
export BUNDLE_VAR_schema=your_workspace_schema

# ─── REQUIRED — which ~/.databrickscfg profile to use ───
# Set up with:  databricks configure --profile <name>
# Selects workspace host + auth token. THIS is where the target workspace comes
# from — databricks.yml does not hardcode workspace.host, so any target name can
# deploy to any workspace via this profile.
export DATABRICKS_CONFIG_PROFILE=your-workspace-profile

# ─── OPTIONAL OVERRIDES — uncomment + edit per target ───

# Baseline ingest path (databricks.yml default: from_source). Valid:
#   synthetic | from_source | from_table
# Harness targets pin this: synth_e2e→synthetic, from_table_e2e→from_table,
# from_source_e2e→from_source. Set it explicitly here to match the target.
# export BUNDLE_VAR_baseline_source=from_source

# Databricks App display name (2-30 chars, lowercase/digits/hyphens), e.g. gsphere-v0-1.
# Unset → per-target composed default; the live `gsphere` target defaults to glucosphere-app.
# export BUNDLE_VAR_app_name=gsphere-v0-1

# Workspace-global resource isolation. harness_suffix is appended to the
# Glucosphere_KA / _Supervisor / _Intelligence / _Forecast_{15,30}min names in
# databricks.yml so a harness/sandbox deploy never collides with the LIVE deploy's
# workspace-global resources.
#   LIVE (gsphere)           → "" (leave empty)
#   gsphere_synth_e2e        → _synth_e2e
#   gsphere_from_table_e2e   → _from_table_e2e
#   gsphere_from_source_e2e  → _from_source_e2e
# export BUNDLE_VAR_harness_suffix=

# Operator initials — suffix harness App + DB-instance names (≤7 chars) so harness
# resources don't collide across deployers or default to an ambiguous "-user". Default `user`.
# export BUNDLE_VAR_dev_initials=mmt
# export BUNDLE_VAR_app_basename=gsphere   # shorten if long initials overflow the 30-char App limit

# from_table mode only — usually leave blank for auto-detect.
# export BUNDLE_VAR_source_catalog=
# export BUNDLE_VAR_source_schema=
# export BUNDLE_VAR_source_table=

# Compute accelerator for the datagen_modeling task (default GPU_1xA10, GA).
# Workspaces WITHOUT Serverless GPU MUST set this empty AND comment out the
# `compute:` block in databricks.yml's datagen_modeling task for CPU fallback.
# export BUNDLE_VAR_compute_accelerator=GPU_1xA10

# ── Reuse / booth targets (identity can't create its own warehouse, and/or the
#    target renders from this env file alone without passing render_app_yaml flags) ──
# Reuse a pre-provisioned SQL warehouse instead of creating one. When set, the target
# omits the sql_warehouses resource and render_app_yaml.py + 09_grant_app_permissions.py
# use this id directly (see databricks.yml `existing_warehouse_id`).
# export BUNDLE_VAR_existing_warehouse_id=
#
# App-assistant agent endpoints — set these so render_app_yaml.py auto-fills app.yaml from
# this file alone (no --mas-endpoint / --ka-endpoint / --genie-space-id flags). Names are
# Agent-Bricks hex (discover via `databricks serving-endpoints list -p <profile>`);
# genie_space_id is a Genie space id. Update if the agents are ever recreated.
#   ORDERING: the warehouse above can be set upfront (a reuse target points at a
#   pre-existing one). The agents, though, are CREATED by the setup job
#   (08_genie_ka_mas.py) — on a COLD first deploy they don't exist yet, so:
#   deploy → run the setup job → discover the ids → set them here (or pass the flags)
#   → re-render → redeploy. On a booth REdeploy they already exist, so renders are flag-free.
# export BUNDLE_VAR_mas_endpoint=mas-<hex>-endpoint
# export BUNDLE_VAR_ka_endpoint=ka-<hex>-endpoint
# export BUNDLE_VAR_genie_space_id=<genie-space-id>

# ════════════════════════════════════════════════════════════════════════════
# REFERENCE — filled example for the live `gsphere` target
# (copy to `.env.bundle.gsphere`, substitute your workspace values)
# ════════════════════════════════════════════════════════════════════════════
#
#   export DATABRICKS_AUTH_STORAGE=plaintext
#   export BUNDLE_VAR_catalog=your_workspace_catalog
#   export BUNDLE_VAR_schema=glucosphere
#   export DATABRICKS_CONFIG_PROFILE=your-workspace-profile
#   # live deploy → no harness_suffix; app defaults to glucosphere-app
#
# Then:
#   source .env.bundle.gsphere
#   databricks bundle deploy -t gsphere                               # pass 1 — creates warehouse
#   uv run python scripts/render_app_yaml.py --target gsphere
#   databricks bundle deploy -t gsphere                               # pass 2 — picks up rendered app.yaml
#   databricks bundle run glucosphere_full_setup -t gsphere
#   databricks bundle run glucosphere_app -t gsphere
