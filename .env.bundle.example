# .env.bundle.example — Single-source-of-truth config for `databricks bundle deploy`.
#
# Workflow:
#   1.  cp .env.bundle.example .env.bundle
#   2.  Fill in the THREE required <FILL_ME_IN> tokens below
#   3.  source .env.bundle
#   4.  databricks bundle deploy -t <target-name>      # pass 1 — creates the bundle-managed warehouse
#   5.  uv run python scripts/render_app_yaml.py --target <target-name>   # discovers warehouse + rewrites app.yaml
#   6.  databricks bundle deploy -t <target-name>      # pass 2 — picks up rendered app.yaml
#   7.  databricks bundle run glucosphere_full_setup -t <target-name>
#   8.  databricks bundle run glucosphere_app -t <target-name>        # deploys App source; without this the App stays UNAVAILABLE
#
# `.env.bundle` is gitignored (each operator maintains their own — values
# are workspace-specific). This `.env.bundle.example` template stays committed.
#
# How values flow: `BUNDLE_VAR_<name>` env vars override the `variables:`
# defaults in `databricks.yml`; `DATABRICKS_CONFIG_PROFILE` selects which
# `~/.databrickscfg` profile supplies workspace host + auth.
#
# NOTE: `warehouse_id` is NOT in this file. The bundle declares a
# `sql_warehouses.glucosphere_warehouse` resource (see databricks.yml) that
# creates the warehouse on first deploy. `render_app_yaml.py` discovers the
# resulting warehouse by name and writes `WAREHOUSE_ID` into `app.yaml`
# automatically.

# NOTE: every variable line below uses `export` — without it the variable
# stays shell-local and the `databricks` CLI subprocess does NOT see it,
# silently falling back to the `databricks.yml` defaults (verified bug 2026-05-27).

# NOTE: on Databricks CLI v1.x (current as of 2026-05), every `databricks ...`
# call needs `DATABRICKS_AUTH_STORAGE=plaintext` in its env or it fails with
# "stored credentials from older CLI versions are no longer used". Harmless
# on older CLI versions. `scripts/smoke_test.py` injects this internally;
# operators running `databricks bundle deploy / run` from the shell should
# export it here once.
export DATABRICKS_AUTH_STORAGE=plaintext

# ─── REQUIRED — Unity Catalog target where the pipeline writes data ───
# Pre-create with `CREATE CATALOG IF NOT EXISTS <name>` if it doesn't exist yet.
export BUNDLE_VAR_catalog=your_workspace_catalog

# ─── REQUIRED — schema (database) inside the catalog above ───
# Pipeline auto-creates this if missing (when SP has CREATE SCHEMA grant).
# The 3 harness targets derive their schemas from this base
# (e.g. `your_workspace_schema_synth_e2e`) so mode isolation is preserved.
export BUNDLE_VAR_schema=your_workspace_schema

# ─── REQUIRED — which `~/.databrickscfg` profile to use ───
# Set up with:  databricks configure --profile <name>
# This selects workspace host + auth token. THIS IS WHERE THE TARGET
# WORKSPACE COMES FROM — `databricks.yml` does not hardcode `workspace.host`,
# so any target name can be deployed to any workspace via this profile.
export DATABRICKS_CONFIG_PROFILE=your-workspace-profile

# ─── OPTIONAL OVERRIDES — uncomment + edit if changing from defaults ───

# Baseline ingest path (default: from_source — downloads HUPA-UCM real CGM data)
# Other options:  synthetic | from_table
# export BUNDLE_VAR_baseline_source=from_source

# Databricks App display name — set to anything (2-30 chars, lowercase/digits/hyphens),
# e.g. gsphere-v0-1. Unset → composed default per target; live deploy → glucosphere-app.
# export BUNDLE_VAR_app_name=gsphere-v0-1

# For `baseline_source=from_table` mode — usually leave blank to use auto-detect
# export BUNDLE_VAR_source_catalog=
# export BUNDLE_VAR_source_schema=
# export BUNDLE_VAR_source_table=

# Harness target isolation (set when sharing a workspace with other deployers).
# Affects ONLY the harness targets (gsphere_synth_e2e / from_table_e2e /
# from_source_e2e), NOT the live target. Default `user` is safe for single-
# deployer use. Keep dev_initials ≤7 chars to stay under the 30-char App limit.
# export BUNDLE_VAR_dev_initials=mmt
# export BUNDLE_VAR_app_basename=gsphere   # shorten if long initials overflow the 30-char App limit

# Compute accelerator for the `datagen_modeling` task (default: GPU_1xA10, GA).
# Workspaces WITHOUT Serverless GPU enabled (some HIPAA CSP / external partner
# workspaces) MUST set this to empty AND comment out the `compute:` block in
# databricks.yml's datagen_modeling task definition for CPU fallback.
# export BUNDLE_VAR_compute_accelerator=GPU_1xA10


# ─── HARNESS MODE SELECTOR — for parallel-validation deploys ───
#
# The 3 harness targets (gsphere_synth_e2e / from_table_e2e /
# from_source_e2e) need their OWN schema isolated from the live deploy.
# Set HARNESS_TYPE before sourcing this file to switch into harness mode;
# the conditional below appends the mode suffix to BUNDLE_VAR_schema:
#
#   # Live deploy (no HARNESS_TYPE set)
#   source .env.bundle && databricks bundle deploy -t gsphere
#
#   # Harness synth_e2e (writes to <base_schema>_synth_e2e)
#   HARNESS_TYPE=synth_e2e source .env.bundle
#   databricks bundle deploy -t gsphere_synth_e2e
#
#   # Harness from_table_e2e (writes to <base>_from_table_e2e;
#   # CTAS-copies from <base>_synth_e2e — run synth_e2e first)
#   HARNESS_TYPE=from_table_e2e source .env.bundle
#   databricks bundle deploy -t gsphere_from_table_e2e
#
#   # Harness from_source_e2e (writes to <base>_from_source_e2e)
#   HARNESS_TYPE=from_source_e2e source .env.bundle
#   databricks bundle deploy -t gsphere_from_source_e2e
#
# Why a HARNESS_TYPE selector here rather than per-target `schema:` overrides
# in databricks.yml? DABs precedence: `BUNDLE_VAR_*` env vars beat per-target
# `variables:` blocks, so the env-side override is the only mechanism that
# actually wins for harness schema isolation.
if [ -n "${HARNESS_TYPE:-}" ]; then
    case "$HARNESS_TYPE" in
        synth_e2e)
            export BUNDLE_VAR_schema="${BUNDLE_VAR_schema}_synth_e2e"
            export BUNDLE_VAR_baseline_source=synthetic
            export BUNDLE_VAR_harness_suffix="_synth_e2e" ;;
        from_table_e2e)
            _orig_schema="$BUNDLE_VAR_schema"
            export BUNDLE_VAR_schema="${_orig_schema}_from_table_e2e"
            export BUNDLE_VAR_source_schema="${_orig_schema}_synth_e2e"
            export BUNDLE_VAR_baseline_source=from_table
            export BUNDLE_VAR_harness_suffix="_from_table_e2e"
            unset _orig_schema ;;
        from_source_e2e)
            export BUNDLE_VAR_schema="${BUNDLE_VAR_schema}_from_source_e2e"
            export BUNDLE_VAR_baseline_source=from_source
            export BUNDLE_VAR_harness_suffix="_from_source_e2e" ;;
        *)
            echo "ERROR: HARNESS_TYPE must be one of: synth_e2e | from_table_e2e | from_source_e2e" >&2
            return 1 ;;
    esac
fi
# BUNDLE_VAR_harness_suffix is also exported above — drives the
# Glucosphere_KA/Supervisor/Intelligence/Forecast_{15,30}min suffix in
# `databricks.yml` task base_parameters so harness deploys don't collide
# with the live deploy's workspace-global resources.


# ════════════════════════════════════════════════════════════════════════════
# REFERENCE — sanitized filled example (substitute your workspace values)
# ════════════════════════════════════════════════════════════════════════════
#
# export BUNDLE_VAR_catalog=your_workspace_catalog
# export BUNDLE_VAR_schema=glucosphere
# export DATABRICKS_CONFIG_PROFILE=your-workspace-profile
#
# # (optional overrides — most users don't need these)
# # export BUNDLE_VAR_baseline_source=synthetic
# # export BUNDLE_VAR_app_name=glucose-fleet-dashboard
#
# Full deploy sequence:
#   source .env.bundle
#   databricks bundle deploy -t gsphere                              # pass 1 — creates warehouse
#   uv run python scripts/render_app_yaml.py --target gsphere
#   databricks bundle deploy -t gsphere                              # pass 2 — picks up rendered app.yaml
#   databricks bundle run glucosphere_full_setup -t gsphere
