bundle:
  name: glucosphere

variables:
  # ───────────────────────────────────────────────────────────────────────
  # Operator-facing variables. ALL values come from `.env.bundle` (gitignored)
  # via BUNDLE_VAR_<name> env vars. See `.env.bundle.example` for the contract.
  # Defaults below are GENERIC placeholders — operator overrides per workspace.
  # ───────────────────────────────────────────────────────────────────────
  catalog:
    description: Unity Catalog catalog (set via BUNDLE_VAR_catalog in .env.bundle)
    default: your_workspace_catalog
  schema:
    description: UC schema / database (set via BUNDLE_VAR_schema in .env.bundle)
    default: glucosphere
  baseline_source:
    description: |
      Baseline ingest path. Valid: "synthetic" | "from_source" | "from_table".
        - synthetic   → 01_synthetic_baseline.py (textbook phenotypes + AR(1))
        - from_source → 02_ingest_real_baseline.py downloads HUPA-UCM from Mendeley
        - from_table  → 02_ingest_real_baseline.py copies from existing UC table
    default: from_source
  source_catalog:
    description: Source catalog for baseline_source=from_table mode (empty → use target catalog)
    default: ""
  source_schema:
    description: Source schema for baseline_source=from_table mode (empty → auto-detect)
    default: ""
  source_table:
    description: Source table for baseline_source=from_table mode (empty → auto-detect)
    default: ""
  app_name:
    description: Databricks App display name
    default: glucosphere-app
  dev_initials:
    description: |
      Personal initials suffix for harness target App + DB instance name
      isolation. Default `user` is safe for single-deployer use. Set in
      .env.bundle (e.g. `mmt`) when sharing a workspace with other deployers
      so harness Apps and DB instances don't collide. Keep ≤7 chars — bounded
      by the 30-char App name limit on the longest harness App.
    default: user
  app_basename:
    description: |
      Base name for harness target App + DB instance resources. Default
      `glucosphere`. Override in .env.bundle to a shorter alias (e.g.
      `your_workspace_target`) if long `dev_initials` push App names past the 30-char limit.
      DB instance names allow up to 63 chars (DNS-compliant), so the
      constraint is App-side only.
    default: glucosphere
  compute_accelerator:
    description: |
      Serverless compute accelerator for the `datagen_modeling` task
      (04_pseudo_data_forecast_modeling.py). Default `GPU_1xA10` (GA;
      ~2.7x faster than CPU per CHANGELOG). Workspaces without Serverless
      GPU enabled (some HIPAA CSP / external partner workspaces) should
      set this to empty string and ALSO comment out the `compute:` block
      in the task definition for CPU fallback. `GPU_8xH100` is Beta and
      only meaningfully outperforms A10 with RUN_OPTUNA_TUNING=true.
    default: GPU_1xA10
  harness_suffix:
    description: |
      Suffix appended to workspace-global resource names (KA/MAS tile,
      Genie space title, forecast serving endpoints) to isolate harness
      deploys from the live deploy. Default `""` for live; the
      HARNESS_TYPE conditional in `.env.bundle` sets it to `_synth_e2e` /
      `_from_table_e2e` / `_from_source_e2e` for the corresponding harness
      targets. Interpolated in `base_parameters` of the tasks that pass
      KA_NAME/MAS_NAME/GENIE_NAME/ENDPOINT_15M/ENDPOINT_30M downstream.
    default: ""

targets:
  # ───────────────────────────────────────────────────────────────────────
  # Live deploy targets. ALL operator-specific config (workspace + data
  # variables) comes from the operator's `.env.bundle`:
  #   - Workspace selection: `DATABRICKS_CONFIG_PROFILE` selects a profile
  #     in `~/.databrickscfg`; that profile's `host` becomes the deploy target.
  #   - Data variables (catalog, schema, etc.): `BUNDLE_VAR_*` env vars
  #     override the `variables:` defaults above.
  # `workspace.host` is intentionally NOT hardcoded per target — operators
  # deploy to whichever workspace their sourced `.env.bundle` profile points
  # at. Target names just identify which set of data-variable defaults apply.
  #
  # `mode: development` on live targets (parallel to harness targets below):
  #   - Auto-prefixes jobs/pipelines/warehouse with `[dev <deployer>]` for
  #     visual consistency in shared workspaces (matches the harness pattern
  #     so all glucosphere items in Workflows UI share the same naming style).
  #   - Pauses schedules/triggers — N/A here (no schedules defined).
  #   - Marks pipeline as development — N/A here (cgm_silver_gold is batch,
  #     `continuous: false`).
  #   - Display-name varies by deployer (e.g. `[dev may_merkletan]` vs
  #     `[dev justin_ward]`); bundle resource IDs stay stable so the App,
  #     Genie, MAS, and serving endpoints (which reference by ID, not name)
  #     are unaffected by who deploys.
  # `mode: production` is the natural future evolution once a CI/CD service
  # principal + shared workspace root_path are provisioned (production mode
  # rejects user-home deploy paths). See Databricks docs:
  # https://docs.databricks.com/dev-tools/bundles/deployment-modes.html
  #
  # Deploy: `source .env.bundle && databricks bundle deploy -t <target>`.
  # No `default: true` on any target — `-t <target>` is always required.
  # ───────────────────────────────────────────────────────────────────────
  your_workspace_target:
    mode: development

  # ─── Adding a new live target ─────────────────────────────────────────
  # Append a stanza like the two above (`name:\n    mode: development`).
  # The operator's `.env.bundle` provides workspace host (via
  # `DATABRICKS_CONFIG_PROFILE` → ~/.databrickscfg profile.host) and data
  # variables (`BUNDLE_VAR_catalog` / `BUNDLE_VAR_schema` / etc.). Adding
  # a `variables:` block here would defeat the SSOT design.

  # ─── Sandbox harness targets ─────────────────────────────────────────────
  #
  # Harness targets share the same `mode: development` as live targets but
  # add a `_<mode>_e2e` suffix to BUNDLE_VAR_schema for data isolation:
  #   - jobs + pipelines auto-prefixed `[dev <username>]` (same as live)
  #   - schedules + triggers paused (N/A — no schedules defined)
  #   - distinguished from live by the `${bundle.target}` suffix in names
  #     (e.g. `*_synth_e2e`) AND by the isolated schema
  #     (`<base>_synth_e2e`)
  #
  # `apps` and `database_instances` resource types do not accept brackets in
  # their names; per-target `name:` overrides below keep them from colliding
  # with the live `glucosphere-app` resource. (database_instances Lakebase
  # is currently commented out at the resources block below — see issue #3.)
  #
  # Override any value below at deploy time via BUNDLE_VAR_<name> — e.g.
  #   BUNDLE_VAR_catalog=my_catalog databricks bundle deploy -t your_workspace_target_synth_e2e ...
  #
  # Usage:
  #   databricks bundle deploy  -t <harness-target> --profile <profile>
  #   databricks bundle run     glucosphere_full_setup -t <harness-target> --profile <profile>
  #   databricks bundle destroy -t <harness-target> --profile <profile> --auto-approve
  #   # bundle destroy does not auto-drop UC schemas — drop manually if needed:
  #   #   DROP SCHEMA <catalog>.<schema> CASCADE
  #
  # Harness schema isolation comes from a `HARNESS_TYPE` env var that the
  # `.env.bundle` conditional appends as a suffix to BUNDLE_VAR_schema
  # (NOT from per-target `schema:` overrides — those are beaten by
  # BUNDLE_VAR_* env vars in DABs precedence).
  #
  # Operator runs:
  #   HARNESS_TYPE=synth_e2e source .env.bundle
  #   databricks bundle deploy -t your_workspace_target_synth_e2e
  #
  # See `.env.bundle.example` for the conditional block. Two operators
  # sharing the workspace can personalize the suffix in their local copies
  # (e.g. `<base>_synth_e2e_<myname>`) to avoid schema collisions.
  your_workspace_target_synth_e2e:
    mode: development
    variables:
      # catalog inherits from BUNDLE_VAR_catalog (operator's .env.bundle).
      # schema isolation: run `HARNESS_TYPE=synth_e2e source .env.bundle`
      # before deploying — the conditional block in .env.bundle appends
      # `_synth_e2e` to BUNDLE_VAR_schema so the harness writes to its own
      # schema. (No per-target `schema:` override here — DABs precedence
      # puts BUNDLE_VAR_* above per-target variables, so the env-side
      # override is the authoritative source of truth.)
      baseline_source: synthetic
      # Mirrors resources.apps.glucosphere_app.name below — kept in sync so
      # `APP_NAME: ${var.app_name}` passed to notebook 09 resolves to the
      # harness App name, not the default `glucosphere-app` (which 404s here).
      app_name: ${var.app_basename}-synth-e2e-${var.dev_initials}
    resources:
      # App names must be 2-30 chars. Suffix `-synth-e2e` distinguishes
      # the harness App from the live `glucosphere-app`.
      apps:
        glucosphere_app:
          name: ${var.app_basename}-synth-e2e-${var.dev_initials}
      # database_instances Lakebase override deferred — see resources.database_instances
      # block below (commented out until app code wires Lakebase in, issue #3).
      # database_instances:
      #   glucosphere_oltp:
      #     name: ${var.app_basename}-oltp-synth-e2e-${var.dev_initials}

  # Validates the from_table mode by CTAS-copying from the synth_e2e harness
  # output into an isolated schema:
  #   1. Run synth_e2e first → populates <catalog>.glucosphere_synth_e2e.diabetes_data
  #   2. Deploy + run from_table_e2e → CTAS-copies into
  #      <catalog>.glucosphere_from_table_e2e.diabetes_data
  # The from_table mode is source-agnostic by design — synthetic-populated
  # source behaves like any other UC table conforming to the diabetes_data
  # contract.
  your_workspace_target_from_table_e2e:
    mode: development
    variables:
      # catalog inherits from BUNDLE_VAR_catalog (.env.bundle).
      # schema + source_schema isolation: run
      #   HARNESS_TYPE=from_table_e2e source .env.bundle
      # before deploying — the conditional block in .env.bundle sets
      # `BUNDLE_VAR_schema=<base>_from_table_e2e` AND
      # `BUNDLE_VAR_source_schema=<base>_synth_e2e` (CTAS-copies from the
      # synth_e2e harness output). No per-target schema overrides here
      # (BUNDLE_VAR_* beats per-target variables in DABs precedence).
      baseline_source: from_table
      source_catalog: ${var.catalog}
      source_table: diabetes_data
      # Mirrors resources.apps.glucosphere_app.name below — see synth_e2e
      # target above for rationale.
      app_name: ${var.app_basename}-table-e2e-${var.dev_initials}
    resources:
      # Parallel naming with synth_e2e harness; kept under the 30-char App limit.
      apps:
        glucosphere_app:
          name: ${var.app_basename}-table-e2e-${var.dev_initials}
      # database_instances Lakebase override deferred — see issue #3.
      # database_instances:
      #   glucosphere_oltp:
      #     name: ${var.app_basename}-oltp-table-e2e-${var.dev_initials}

  # Validates the from_source mode end-to-end: exercises the Mendeley
  # download + parse path + source-adaptive sampler against real HUPA-UCM
  # source distribution. Isolated sandbox schema — does not affect the
  # live target's data.
  your_workspace_target_from_source_e2e:
    mode: development
    variables:
      # catalog inherits from BUNDLE_VAR_catalog (.env.bundle).
      # schema isolation: run
      #   HARNESS_TYPE=from_source_e2e source .env.bundle
      # before deploying — the conditional block in .env.bundle appends
      # `_from_source_e2e` to BUNDLE_VAR_schema. (No per-target `schema:`
      # override; BUNDLE_VAR_* beats per-target variables in DABs precedence.)
      baseline_source: from_source
      # Mirrors resources.apps.glucosphere_app.name below — see synth_e2e
      # target above for rationale.
      app_name: ${var.app_basename}-source-e2e-${var.dev_initials}
    resources:
      apps:
        glucosphere_app:
          name: ${var.app_basename}-source-e2e-${var.dev_initials}
      # database_instances Lakebase override deferred — see issue #3.
      # database_instances:
      #   glucosphere_oltp:
      #     name: ${var.app_basename}-oltp-source-e2e-${var.dev_initials}

resources:

  # ---------------------------------------------------------------------------
  # DLT Pipeline: Silver & Gold CGM Views
  # Reads from pipeline_data volume (populated by setup job) and produces:
  #   silver_patient_registry, silver_device_telemetry_stream,
  #   silver_patient_readings, gold_patient_device_readings
  # ---------------------------------------------------------------------------
  pipelines:
    cgm_silver_gold:
      name: glucosphere-cgm-silver-gold-${bundle.target}
      catalog: ${var.catalog}
      target: ${var.schema}
      channel: CURRENT
      continuous: false
      serverless: true
      libraries:
        - file:
            path: Data_DataGen_ModelForecast/utils/additional_patient_info/transformations.sql
      configuration:
        catalog: ${var.catalog}
        schema: ${var.schema}

  # ---------------------------------------------------------------------------
  # Job: End-to-End Glucosphere Setup
  #
  # Task DAG (ASCII):
  #
  #   validate_baseline_source       (enum + banner — fail-fast typo guard)
  #            ↓
  #   check_pre_baseline_grants      (verify catalog/schema/table/volume/function perms before any work)
  #            ↓
  #   dispatch_baseline_source       (condition_task: == "synthetic"?)
  #            ↓                ↓
  #    true ↙               ↘ false
  #   generate_synthetic_   ingest_real_baseline    (writes diabetes_data
  #     baseline             [+ baseline_timeseries  + baseline_timeseries
  #                          + baseline_windows_     + baseline_windows_
  #                          metadata via C.4 port]   metadata]
  #            ↘                 ↙
  #   sanity_summary             (run_if AT_LEAST_ONE_SUCCESS;
  #                               asserts diabetes_data non-empty + plausible)
  #            ↓
  #   datagen_modeling           (04_*: pseudo CGM data + XGBoost training)
  #            ↓
  #   incident_inference         (05_*: device calibration bug + inference)
  #            ↓                            ↓
  #   deploy_model_endpoints       generate_patient_device_data
  #            ↓                       ↓                ↓
  #            ↘            create_patient_registry  create_device_telemetry
  #             ↘                      ↓
  #              ↘             run_dlt_pipeline      (silver/gold from pipeline_data)
  #               ↘                    ↓
  #                ↘          create_genie_ka_mas    (KA + Genie + MAS endpoints)
  #                 ↘                  ↓
  #                  ↘    check_post_endpoint_grants (verify KA/MAS/Genie exist before grant_app_permissions)
  #                   ↘                ↓
  #                    ↘     grant_app_permissions  (app SP access on UC + endpoints + warehouse;
  #                                                    warehouse discovered by deterministic name
  #                                                    from bundle's sql_warehouses resource)
  # ---------------------------------------------------------------------------
  jobs:
    glucosphere_full_setup:
      name: glucosphere-full-setup-${bundle.target}
      environments:
        - environment_key: default
          spec:
            client: "1"
        # GPU environment for Serverless GPU tasks (client "4"/"5" required;
        # client "1" is not GPU-compatible). Used by `datagen_modeling` task below.
        - environment_key: gpu_default
          spec:
            client: "5"
      tasks:
        # ── Preflight: validate baseline_source + print run banner ─────────
        - task_key: validate_baseline_source
          description: Validate baseline_source enum + print run banner (fail-fast on typos)
          max_retries: 0
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/validate_baseline_source.py
            base_parameters:
              BASELINE_SOURCE: ${var.baseline_source}
              CATALOG_NAME:    ${var.catalog}
              SCHEMA_NAME:     ${var.schema}
              SOURCE_CATALOG:  ${var.source_catalog}
              SOURCE_SCHEMA:   ${var.source_schema}
              SOURCE_TABLE:    ${var.source_table}
          environment_key: default

        # ── Pre-baseline grants check ──────────────────────────────────────
        - task_key: check_pre_baseline_grants
          description: Verify UC permissions needed by baseline + modeling tasks (fail-fast on missing grants)
          max_retries: 0
          depends_on:
            - task_key: validate_baseline_source
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/check_pre_baseline_grants.py
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
          environment_key: default

        # ── Baseline ingest dispatch ───────────────────────────────────────
        - task_key: dispatch_baseline_source
          description: Branch on ${var.baseline_source} — synthetic vs real baseline ingest
          depends_on:
            - task_key: check_pre_baseline_grants
          condition_task:
            op: EQUAL_TO
            left: ${var.baseline_source}
            right: "synthetic"

        - task_key: generate_synthetic_baseline
          description: Generate synthetic baseline CGM data (diabetes_data + baseline_timeseries)
          max_retries: 0
          depends_on:
            - task_key: dispatch_baseline_source
              outcome: "true"
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/01_synthetic_baseline.py
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
          environment_key: default

        - task_key: ingest_real_baseline
          description: Ingest real baseline (HUPA-UCM download or existing UC table — sub-option set inside notebook)
          max_retries: 0
          depends_on:
            - task_key: dispatch_baseline_source
              outcome: "false"
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/02_ingest_real_baseline.py
            base_parameters:
              CATALOG_NAME:    ${var.catalog}
              SCHEMA_NAME:     ${var.schema}
              BASELINE_SOURCE: ${var.baseline_source}
              SOURCE_CATALOG:  ${var.source_catalog}
              SOURCE_SCHEMA:   ${var.source_schema}
              SOURCE_TABLE:    ${var.source_table}
          environment_key: default

        # ── Sanity gate before heavy downstream modeling ───────────────────
        - task_key: sanity_summary
          description: Assert diabetes_data is non-empty + plausible before modeling
          max_retries: 0
          depends_on:
            - task_key: generate_synthetic_baseline
            - task_key: ingest_real_baseline
          run_if: AT_LEAST_ONE_SUCCESS
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/sanity_summary.py
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
          environment_key: default

        - task_key: datagen_modeling
          description: Generate synthetic CGM data and train XGBoost glucose forecast models
          max_retries: 0
          depends_on:
            - task_key: sanity_summary
          # Serverless GPU compute — enables MLflow GPUMonitor (system/gpu_* metrics)
          # + XGBoost CUDA training on a single A10. Accelerator value comes
          # from `${var.compute_accelerator}` — see top of file for description
          # + CPU-fallback instructions for workspaces without Serverless GPU.
          # Alternative accelerator: GPU_8xH100 (Beta; 8x H100 distributed; needs
          # workspace admin to enable "AI Runtime Beta Feature preview"). A10 is GA
          # and sufficient for this workload (XGBoost on ~1000 pseudo-patients,
          # RUN_OPTUNA_TUNING=false).
          # NOTE: GPU_8xH100 would only meaningfully outperform GPU_1xA10 if
          # RUN_OPTUNA_TUNING is flipped to "true" — the 4-way parallel Optuna
          # block in 04_*.py (joblib Parallel n_jobs=4, "one per GPU")
          # serializes on 1 GPU but can fan out across 4 of 8 H100s. See
          # CHANGELOG for empirical GPU-vs-CPU timing comparison.
          compute:
            hardware_accelerator: ${var.compute_accelerator}
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/04_pseudo_data_forecast_modeling.py
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
              ENV: dev
              RUN_OPTUNA_TUNING: "false"
          environment_key: gpu_default

        - task_key: incident_inference
          description: >
            Simulate device calibration bug incident, run inference,
            and produce pseudo_incident_7d_labeled table consumed by app.
          max_retries: 0
          depends_on:
            - task_key: datagen_modeling
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/05_incident_inference_bidirectional.py
            base_parameters:
              CATALOG_NAME:     ${var.catalog}
              SCHEMA_NAME:      ${var.schema}
              ENV: dev
              INCLUDE_INCIDENT: "true"
          environment_key: default

        - task_key: deploy_model_endpoints
          description: Deploy XGBoost 15m and 30m forecast models as serving endpoints
          max_retries: 0
          depends_on:
            - task_key: datagen_modeling
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/07_deploy_serving_endpoints.py
            base_parameters:
              CATALOG_NAME:   ${var.catalog}
              SCHEMA_NAME:    ${var.schema}
              # Workspace-global endpoint names — harness_suffix isolates
              # harness deploys from the live forecast endpoints.
              ENDPOINT_15M:   "Glucosphere_Forecast_15min${var.harness_suffix}"
              ENDPOINT_30M:   "Glucosphere_Forecast_30min${var.harness_suffix}"
          environment_key: default

        # ── Landing Zone Population ────────────────────────────────────────
        # generate_patient_device_data must run first — it creates the patient_device
        # table (from pseudo_incident_7d_labeled) that the registry and telemetry
        # notebooks depend on for patient/device IDs.
        - task_key: generate_patient_device_data
          description: Create patient_device table from pseudo_incident_7d_labeled
          max_retries: 0
          depends_on:
            - task_key: incident_inference
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/additional_patient_info/Create Patient_Device Table.ipynb
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
          environment_key: default

        - task_key: create_patient_registry
          description: Generate synthetic patient registry parquet files into pipeline_data volume
          max_retries: 0
          depends_on:
            - task_key: generate_patient_device_data
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/additional_patient_info/Create Raw Patient_Registry Data.ipynb
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
          environment_key: default

        - task_key: create_device_telemetry
          description: Generate synthetic device telemetry parquet files into pipeline_data volume
          max_retries: 0
          depends_on:
            - task_key: generate_patient_device_data
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/additional_patient_info/Create Raw Device Data.ipynb
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
          environment_key: default

        # ── DLT Pipeline ──────────────────────────────────────────────────
        - task_key: run_dlt_pipeline
          description: Run DLT pipeline to produce silver/gold CGM tables from pipeline_data
          max_retries: 0
          depends_on:
            - task_key: create_patient_registry
            - task_key: create_device_telemetry
            - task_key: deploy_model_endpoints
          pipeline_task:
            pipeline_id: ${resources.pipelines.cgm_silver_gold.id}
            full_refresh: false

        # ── Data sanity gate (clinical plausibility) ──────────────────────
        # Fails the run if clinically-impossible records reached gold, so implausible
        # data (9yo T2D, >55 gestational, glucose 0, no-forecast patients) can never
        # silently reach the app/demo. Gates the intelligence + app layers below.
        - task_key: data_sanity_checks
          description: Clinical-plausibility gate — fail on T2D<13, implausible gestational age, glucose outside [40,400], or patients with no forecast row
          max_retries: 0
          depends_on:
            - task_key: run_dlt_pipeline
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/data_sanity_checks.py
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
          environment_key: default

        # ── Intelligence Layer ────────────────────────────────────────────
        - task_key: create_genie_ka_mas
          description: Create WHO Knowledge Assistant, Genie room, and Multi-Agent Supervisor endpoint
          max_retries: 0
          depends_on:
            - task_key: data_sanity_checks
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/08_genie_ka_mas.py
            base_parameters:
              CATALOG_NAME:      ${var.catalog}
              SCHEMA_NAME:       ${var.schema}
              KA_NAME:           "Glucosphere_KA${var.harness_suffix}"
              GENIE_NAME:        "Glucosphere_Intelligence${var.harness_suffix}"
              MAS_NAME:           "Glucosphere_Supervisor${var.harness_suffix}"
              BUNDLE_TARGET:     ${bundle.target}
          environment_key: default

        # ── Post-endpoint grants check ────────────────────────────────────
        - task_key: check_post_endpoint_grants
          description: Verify KA + MAS + Genie resources exist before grant_app_permissions runs
          max_retries: 0
          depends_on:
            - task_key: create_genie_ka_mas
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/utils/check_post_endpoint_grants.py
            base_parameters:
              CATALOG_NAME: ${var.catalog}
              SCHEMA_NAME:  ${var.schema}
              KA_NAME:      "Glucosphere_KA${var.harness_suffix}"
              MAS_NAME:     "Glucosphere_Supervisor${var.harness_suffix}"
              GENIE_NAME:   "Glucosphere_Intelligence${var.harness_suffix}"
          environment_key: default

        # ── Permissions ───────────────────────────────────────────────────
        - task_key: grant_app_permissions
          description: >
            Grant the deployed app's service principal access to the catalog,
            all serving endpoints, the SQL warehouse, and the Genie space.
            WAREHOUSE_ID is left empty so the notebook discovers the
            bundle-managed warehouse by deterministic name (see
            sql_warehouses.glucosphere_warehouse resource below).
          max_retries: 0
          depends_on:
            - task_key: check_post_endpoint_grants
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/09_grant_app_permissions.py
            base_parameters:
              CATALOG_NAME:      ${var.catalog}
              SCHEMA_NAME:       ${var.schema}
              APP_NAME:          ${var.app_name}
              # WAREHOUSE_ID empty → 09 discovers bundle-managed warehouse by
              # name pattern `glucosphere-warehouse-${bundle.target}`.
              # BUNDLE_TARGET passed in so 09 knows which target's warehouse to find.
              WAREHOUSE_ID:      ""
              BUNDLE_TARGET:     ${bundle.target}
              # KA/MAS endpoint names and Genie space ID are auto-discovered when
              # left empty. The *_NAME params anchor the discovery to the exact
              # tile/space created by 08 (look up serving_endpoint_name from the
              # tile by exact name match), avoiding substring matches that can
              # mis-resolve in workspaces with multiple KA/MAS/Genie resources.
              MAS_ENDPOINT_NAME: ""
              KA_ENDPOINT_NAME:  ""
              GENIE_SPACE_ID:    ""
              KA_NAME:           "Glucosphere_KA${var.harness_suffix}"
              MAS_NAME:          "Glucosphere_Supervisor${var.harness_suffix}"
              GENIE_NAME:        "Glucosphere_Intelligence${var.harness_suffix}"
          environment_key: default

    # -------------------------------------------------------------------------
    # Standalone analytics — distribution comparison across baseline modes
    # -------------------------------------------------------------------------
    # On-demand: operator triggers when ≥2 baseline modes have been populated
    # (e.g. live synthetic + a from_source sandbox snapshot, or two real
    # snapshots from different sources). NOT part of glucosphere_full_setup.
    glucosphere_distribution_comparison:
      name: glucosphere-distribution-comparison-${bundle.target}
      description: |
        Compare diabetes_data distributions across baseline modes side-by-side.
        Emits headline stats (n, percentiles, glycemic buckets) + KS test +
        matplotlib plots (overlaid histograms, boxplot, bucket bars). Plots
        embed inline in cell output AND save to a UC Volume.

        Operator MUST set at least 2 of {SYNTHETIC_SCHEMA, FROM_SOURCE_SCHEMA,
        FROM_TABLE_SCHEMA} to non-empty schema names containing diabetes_data.
        The notebook validates the ≥2 precondition and fails fast otherwise.
      environments:
        - environment_key: default
          spec:
            client: "1"
      tasks:
        - task_key: distribution_comparison
          description: Compute side-by-side stats and render inline plots
          max_retries: 0
          notebook_task:
            notebook_path: Data_DataGen_ModelForecast/03_compare_baseline_modes.py
            base_parameters:
              CATALOG_NAME:             ${var.catalog}
              # Operator must override at least 2 of the next 3 at run time.
              # Defaults are empty so the notebook fails fast if launched
              # without intent (avoids silently comparing the live schema
              # against itself with a misleading "synthetic" label).
              SYNTHETIC_SCHEMA:         ""
              FROM_SOURCE_SCHEMA:  ""
              FROM_TABLE_SCHEMA:   ""
              # Optional: archive the comparison summary as a delta table.
              WRITE_SUMMARY_TO_SCHEMA:  ""
              # Plots: written under the live schema's `comparison_plots`
              # volume (auto-created by the notebook if missing).
              PLOTS_OUTPUT_VOLUME_PATH: /Volumes/${var.catalog}/${var.schema}/comparison_plots
          environment_key: default

  # ---------------------------------------------------------------------------
  # Lakebase: OLTP alert state cache — DEFERRED (planned follow-up, issue #3)
  # ---------------------------------------------------------------------------
  # Re-enable when the Lakebase path is actually wired into
  # App/databricks/app.py (no app code reads from this instance today).
  # Note: CU_1 instances bill continuously while deployed, so keeping this
  # commented avoids paying for unused infra. Also: the hardcoded
  # `glucosphere-oltp-mmt-aws-usw2` name would need to become per-target
  # before this can deploy outside the live your_workspace_target target.
  #
  # Original block (re-enable + parameterize name before reactivating):
  #
  # database_instances:
  #   glucosphere_oltp:
  #     # Lakebase requires DNS-compliant names (alphanumeric + hyphens only).
  #     # Cannot use `${bundle.target}` directly because targets use underscores.
  #     # When adding new targets, override this in the target's variables block.
  #     name: glucosphere-oltp-mmt-aws-usw2
  #     capacity: CU_1
  #     # enable_pg_native_login defaults to false — connection uses Databricks
  #     # OAuth credentials (app SP). Flip to true if a password-based Postgres
  #     # client is needed for debug / migrations.

  # ---------------------------------------------------------------------------
  # SQL Warehouse: bundle-managed (powers App's /api/sql/query + comparison job)
  # ---------------------------------------------------------------------------
  # Bundle creates this warehouse on first deploy. Name pattern is
  # `glucosphere-warehouse-${bundle.target}` (with `[dev USER]` prefix when a
  # target uses `mode: development`).
  #
  # Configured as a Serverless SQL Warehouse: `warehouse_type: PRO` +
  # `enable_serverless_compute: true` is the canonical serverless combination
  # (PRO is the modern warehouse tier; CLASSIC is the legacy non-serverless
  # tier). `cluster_size: "2X-Small"` is the smallest serverless size —
  # escalate only on demonstrated workload need.
  #
  # Discovery flow:
  #   - `09_grant_app_permissions.py` discovers this warehouse by name suffix
  #     and grants CAN_USE to the App SP.
  #   - `scripts/render_app_yaml.py` discovers by same name + writes
  #     `WAREHOUSE_ID` into App/databricks/app.yaml's env block.
  #   - App's `/api/sql/query` uses `WAREHOUSE_ID` env var with the direct
  #     Statement Execution API to route SQL to this warehouse.
  sql_warehouses:
    glucosphere_warehouse:
      name: glucosphere-warehouse-${bundle.target}
      cluster_size: "2X-Small"
      enable_serverless_compute: true
      warehouse_type: PRO
      # auto_stop_mins=30 keeps the warehouse warm during demo sessions —
      # the landing page (IncidentImpactChart + GlucoseAbsoluteChart +
      # GlucoseTimelineChart) hits the warehouse on every page load, and
      # cold-start adds ~5-15 sec on top of query time when the warehouse
      # has stopped. 30 min strikes a balance: warm enough for typical
      # demo / review sessions without leaving compute idle overnight.
      auto_stop_mins: 30
      min_num_clusters: 1
      max_num_clusters: 1

  # ---------------------------------------------------------------------------
  # App: Glucosphere App (front-end branding: "GlucoStream Intelligence")
  # ---------------------------------------------------------------------------
  apps:
    glucosphere_app:
      name: ${var.app_name}
      description: >
        Glucosphere CGM Intelligence Dashboard — continuous glucose monitoring
        platform with AI-powered diabetes coach insights, device anomaly detection,
        and fleet-level incident analysis.
      source_code_path: App/databricks
